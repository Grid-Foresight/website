---

---

<section id="integrations" class="bg-bg-base py-16 md:py-24" aria-labelledby="integrations-heading">
	<div class="mx-auto max-w-[1280px] px-6 md:px-8">
		<div class="mb-12 text-center">
			<h2
				id="integrations-heading"
				class="font-display text-3xl font-bold tracking-tight text-text-primary sm:text-4xl"
			>
				Connects to your data
			</h2>
			<p class="mt-4 text-text-secondary">
				Bring any energy data source. GridForesight handles format detection,
				timezone normalization, and gap resolution.
			</p>
		</div>

		<div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
			<div class="flex items-center gap-2.5">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-secondary" aria-hidden="true">
					<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
					<path d="M14 2v4a2 2 0 0 0 2 2h4" />
					<path d="M12 12v6" />
					<path d="m15 15-3-3-3 3" />
				</svg>
				<span class="font-display text-sm text-text-primary">CSV</span>
			</div>

			<span class="hidden h-5 w-px bg-bg-subtle sm:block" aria-hidden="true"></span>

			<div class="flex items-center gap-2.5">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-secondary" aria-hidden="true">
					<path d="M12 22v-5" />
					<path d="M9 8V2" />
					<path d="M15 8V2" />
					<path d="M18 8v5a4 4 0 0 1-4 4h-4a4 4 0 0 1-4-4V8Z" />
				</svg>
				<span class="font-display text-sm text-text-primary">REST API</span>
			</div>

			<span class="hidden h-5 w-px bg-bg-subtle sm:block" aria-hidden="true"></span>

			<div class="flex items-center gap-2.5">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-secondary" aria-hidden="true">
					<path d="m12 14 4-4" />
					<path d="M3.34 19a10 10 0 1 1 17.32 0" />
				</svg>
				<span class="font-display text-sm text-text-primary">SCADA</span>
			</div>

			<span class="hidden h-5 w-px bg-bg-subtle sm:block" aria-hidden="true"></span>

			<div class="flex items-center gap-2.5">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-secondary" aria-hidden="true">
					<path d="M12 2v2" />
					<path d="m4.93 4.93 1.41 1.41" />
					<path d="M20 12h2" />
					<path d="m19.07 4.93-1.41 1.41" />
					<path d="M15.947 12.65a4 4 0 0 0-5.925-4.128" />
					<path d="M13 22H7a5 5 0 1 1 4.9-6H13a3 3 0 0 1 0 6Z" />
				</svg>
				<span class="font-display text-sm text-text-primary">Weather</span>
			</div>
		</div>

		<p class="mt-8 text-center text-sm text-text-secondary">
			Time-series data in any resolution. Automatic timezone detection and UTC normalization.
		</p>
	</div>
</section>
