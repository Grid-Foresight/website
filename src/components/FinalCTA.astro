---
import { config } from "../config";

const { heading, description, form } = config.cta;
const {
	accessKey,
	emailSubject,
	fields,
	submitButton,
	submittingButton,
	successMessage,
	errorMessage,
} = form;
---

<section id="contact" aria-labelledby="cta-heading" class="bg-white py-20 md:py-32">
	<div class="mx-auto max-w-[var(--width-content)] px-6">
		<div class="mx-auto max-w-[560px] text-center">
			<h2
				id="cta-heading"
				class="font-display text-3xl font-semibold tracking-tight text-slate-900 md:text-[40px]"
			>
				{heading}
			</h2>
			<p class="mx-auto mt-4 max-w-[680px] text-lg text-slate-600">{description}</p>
		</div>

		<form
			action="https://api.web3forms.com/submit"
			method="POST"
			id="contact-form"
			class="mx-auto mt-12 max-w-[560px]"
			novalidate
		>
			<input type="hidden" name="access_key" value={accessKey} />
			<input type="hidden" name="subject" value={emailSubject} />
			<input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

			<div class="flex flex-col gap-4">
				<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
					<div class="flex flex-col gap-1.5">
						<label for="name" class="text-sm font-medium text-slate-700">{fields.name.label}</label>
						<input
							type="text"
							id="name"
							name="name"
							required
							placeholder={fields.name.placeholder}
							class="rounded-[var(--radius-default)] border border-slate-200 px-4 py-3 text-base text-slate-900 placeholder:text-slate-400 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
						/>
					</div>
					<div class="flex flex-col gap-1.5">
						<label for="email" class="text-sm font-medium text-slate-700">{fields.email.label}</label>
						<input
							type="email"
							id="email"
							name="email"
							required
							placeholder={fields.email.placeholder}
							class="rounded-[var(--radius-default)] border border-slate-200 px-4 py-3 text-base text-slate-900 placeholder:text-slate-400 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
						/>
					</div>
				</div>

				<div class="flex flex-col gap-1.5">
					<label for="organization" class="text-sm font-medium text-slate-700">{fields.organization.label}</label>
					<input
						type="text"
						id="organization"
						name="organization"
						placeholder={fields.organization.placeholder}
						class="rounded-[var(--radius-default)] border border-slate-200 px-4 py-3 text-base text-slate-900 placeholder:text-slate-400 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
					/>
				</div>

				<div class="flex flex-col gap-1.5">
					<label for="message" class="text-sm font-medium text-slate-700">{fields.message.label}</label>
					<textarea
						id="message"
						name="message"
						required
						rows="4"
						placeholder={fields.message.placeholder}
						class="resize-none rounded-[var(--radius-default)] border border-slate-200 px-4 py-3 text-base text-slate-900 placeholder:text-slate-400 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
					></textarea>
				</div>

				<button
					type="submit"
					id="submit-btn"
					class="mt-2 inline-flex w-full cursor-pointer items-center justify-center rounded-[var(--radius-default)] bg-primary px-8 py-3.5 text-base font-semibold text-white transition-all duration-200 hover:scale-[1.01] hover:bg-primary-hover focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:scale-100 disabled:opacity-60"
				>
					{submitButton}
				</button>
			</div>

			<p id="form-result" aria-live="polite" class="mt-4 hidden text-center text-sm font-medium"></p>
		</form>
	</div>
</section>

<script define:vars={{ submittingButton, submitButton, successMessage, errorMessage }}>
	const form = document.getElementById("contact-form");
	const btn = document.getElementById("submit-btn");
	const result = document.getElementById("form-result");

	function setFieldError(el, hasError) {
		el.classList.toggle("field-invalid", hasError);
	}

	form.addEventListener("submit", async (e) => {
		e.preventDefault();

		const nameEl = form.querySelector("#name");
		const emailEl = form.querySelector("#email");
		const messageEl = form.querySelector("#message");
		const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

		const nameVal = nameEl.value.trim();
		const emailVal = emailEl.value.trim();
		const messageVal = messageEl.value.trim();
		const emailValid = emailPattern.test(emailVal);

		setFieldError(nameEl, !nameVal);
		setFieldError(emailEl, !emailVal || !emailValid);
		setFieldError(messageEl, !messageVal);

		if (!nameVal || !emailVal || !messageVal) {
			result.textContent = "Please fill in your name, email, and message.";
			result.classList.remove("hidden", "text-primary");
			result.classList.add("text-red-600");
			return;
		}

		if (!emailValid) {
			result.textContent = "Please enter a valid email address.";
			result.classList.remove("hidden", "text-primary");
			result.classList.add("text-red-600");
			return;
		}

		btn.disabled = true;
		btn.textContent = submittingButton;
		result.classList.add("hidden");

		const data = new FormData(form);
		const response = await fetch("https://api.web3forms.com/submit", {
			method: "POST",
			body: data,
		});
		const json = await response.json();

		if (json.success) {
			result.textContent = successMessage;
			result.classList.remove("hidden", "text-red-600");
			result.classList.add("text-primary");
			form.reset();
			form.querySelectorAll(".field-invalid").forEach(el => el.classList.remove("field-invalid"));
		} else {
			result.textContent = errorMessage;
			result.classList.remove("hidden", "text-primary");
			result.classList.add("text-red-600");
		}

		btn.disabled = false;
		btn.textContent = submitButton;
	});
</script>
