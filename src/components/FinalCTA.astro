---
const appUrl = "https://app.gridforesight.com";
---

<section class="bg-primary px-6 py-16 md:py-24">
	<div class="mx-auto max-w-[1280px]">
		<div class="mx-auto max-w-2xl text-center">
			<h2 class="font-display text-3xl font-bold text-white md:text-[40px]">
				Start forecasting in minutes
			</h2>
			<p class="mt-4 font-body text-lg text-indigo-100">
				Upload your first dataset, train a model, and see predictions — all before your coffee
				gets cold.
			</p>

			<div class="mt-8">
				<a
					href={appUrl}
					class="inline-block rounded-lg bg-white px-6 py-3 font-body text-base font-semibold text-primary transition-colors hover:bg-slate-50"
					rel="noopener noreferrer"
				>
					Start Forecasting
				</a>
			</div>
		</div>
	</div>
</section>
