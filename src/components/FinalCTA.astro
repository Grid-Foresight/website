---
import { config } from "../config";

const { appUrl } = config.site;
const { heading, description, button } = config.cta;
---

<section aria-labelledby="cta-heading" class="bg-white py-20 md:py-32">
	<div class="mx-auto max-w-[var(--width-content)] px-6 text-center">
		<h2
			id="cta-heading"
			class="font-display text-3xl font-semibold tracking-tight text-slate-900 md:text-[40px]"
		>
			{heading}
		</h2>
		<p class="mx-auto mt-4 max-w-[680px] text-lg text-slate-600">{description}</p>

		<div class="mt-10 flex items-center justify-center">
			<a
				href={appUrl}
				class="inline-flex rounded-[var(--radius-default)] bg-primary px-8 py-3.5 text-base font-semibold text-white transition-all duration-200 hover:scale-[1.02] hover:bg-primary-hover focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:ring-offset-2"
				target="_blank"
				rel="noopener noreferrer"
			>
				{button}
			</a>
		</div>
	</div>
</section>
