---
import { ArrowRight } from "@lucide/astro";

const appUrl = "https://app.gridforesight.com";
const labUrl = "https://gridforesight.ca/";
---

<section class="section-reveal bg-bg-dark py-28 lg:py-32">
	<div class="mx-auto max-w-[var(--max-width)] px-6 text-center">
		<p class="font-display text-[clamp(2.5rem,5vw,4rem)] font-bold text-primary">
			40% More Accurate.
		</p>

		<h2 class="mt-4 font-display text-[clamp(1.5rem,3vw,2.5rem)] font-bold text-text-on-dark">
			Ready to see what research-grade forecasting does for your grid?
		</h2>

		<div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
			<a
				href={appUrl}
				class="inline-flex items-center gap-2 rounded-full bg-primary px-7 py-3 font-display text-base font-semibold text-white transition-all hover:bg-primary-hover hover:shadow-lg"
			>
				Start Forecasting
				<ArrowRight size={18} />
			</a>
			<a
				href={labUrl}
				class="inline-flex items-center gap-2 rounded-full border border-primary px-7 py-3 font-display text-base font-semibold text-primary transition-all hover:bg-primary/10"
			>
				Explore the Lab
			</a>
		</div>

		<p class="mt-8 text-sm text-neutral-500">
			From the Grid Foresight Lab &mdash; 50+ publications, 10+ years, one production platform.
		</p>
	</div>
</section>
