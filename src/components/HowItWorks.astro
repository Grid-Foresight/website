---
import { config } from "../config";

const { heading, steps } = config.howItWorks;
---

<section id="how-it-works" aria-labelledby="how-it-works-heading" class="py-16 md:py-24">
	<div class="mx-auto max-w-[960px] px-6">
		<h2
			id="how-it-works-heading"
			class="mb-12 text-center font-display text-3xl font-semibold tracking-tight text-slate-900 md:mb-16 md:text-[40px]"
		>
			{heading}
		</h2>

		<div class="flex flex-col items-stretch gap-8 md:flex-row md:items-start md:gap-0">
			{
				steps.map((step, i) => (
					<>
						<div class="flex flex-1 flex-col items-center text-center">
							<div class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-primary font-display text-base font-bold text-white">
								{i + 1}
							</div>
							<h3 class="font-display text-xl font-semibold tracking-tight text-slate-900">
								{step.title}
							</h3>
							<p class="mt-2 max-w-[280px] text-base text-slate-600">
								{step.description}
							</p>
						</div>
						{i < steps.length - 1 && (
							<div class="hidden flex-shrink-0 self-center md:block">
								<div class="h-px w-12 bg-slate-200 lg:w-16" />
							</div>
						)}
					</>
				))
			}
		</div>
	</div>
</section>
