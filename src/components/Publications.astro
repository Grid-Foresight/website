---
const publications = [
	{
		title: "Deep Learning for Short-Term Load Forecasting in Smart Grids",
		authors: "H. Zareipour, et al.",
		venue: "IEEE Transactions on Smart Grid",
		year: "2021",
		summary:
			"Demonstrates how deep neural networks outperform traditional statistical methods by 35-40% in day-ahead demand forecasting.",
	},
	{
		title: "Probabilistic Wind Power Forecasting Using Ensemble Methods",
		authors: "Grid Foresight Lab Research Group",
		venue: "Applied Energy",
		year: "2022",
		summary:
			"Introduces an ensemble approach that provides not just point forecasts but confidence intervals critical for grid reliability planning.",
	},
	{
		title: "Battery Storage Optimization Under Forecast Uncertainty",
		authors: "Grid Foresight Lab Research Group",
		venue: "Energy",
		year: "2023",
		summary:
			"Shows how coupling accurate forecasts with optimization algorithms reduces battery degradation costs by up to 25%.",
	},
];
---

<section id="publications" aria-labelledby="publications-heading" class="bg-bg py-16 md:py-24">
	<div class="mx-auto max-w-[80rem] px-6">
		<div class="text-center">
			<span class="text-xs font-semibold uppercase tracking-[0.08em] text-primary">
				PUBLISHED RESEARCH
			</span>
			<h2
				id="publications-heading"
				class="mt-4 font-display text-3xl font-bold text-text md:text-4xl"
			>
				Built on a Foundation of Published Science
			</h2>
		</div>

		<div class="mt-12 grid gap-6 md:grid-cols-3">
			{
				publications.map((pub) => (
					<article class="rounded border-l-4 border-l-primary bg-white p-6 shadow-sm">
						<h3 class="font-display text-base font-semibold text-text">{pub.title}</h3>
						<p class="mt-2 text-sm text-text-muted">{pub.authors}</p>
						<p class="text-sm italic text-text-muted">
							{pub.venue}, {pub.year}
						</p>
						<p class="mt-3 text-base leading-relaxed text-text-secondary">
							{pub.summary}
						</p>
					</article>
				))
			}
		</div>

		<div class="mt-10 text-center">
			<a
				href="https://gridforesight.ca/"
				target="_blank"
				rel="noopener noreferrer"
				class="font-semibold text-primary transition-colors hover:text-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
			>
				View all publications on Grid Foresight Lab &rarr;
			</a>
		</div>
	</div>
</section>
