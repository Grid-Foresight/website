---
interface Props {
	title: string;
	dark?: boolean;
	id?: string;
	eyebrow?: string;
}

const { title, dark = false, id, eyebrow } = Astro.props;
---

<div class="animate-on-scroll mb-8">
	{
		eyebrow && (
			<p
				class:list={[
					"font-[var(--font-mono)] text-xs font-semibold uppercase tracking-[0.15em] sm:text-sm",
					"text-[var(--color-accent)]",
				]}
			>
				{eyebrow}
			</p>
		)
	}
	<h2
		id={id}
		class:list={[
			"mt-3 font-[var(--font-display)] text-[28px] font-semibold leading-[1.15] tracking-[-0.015em] sm:text-[42px]",
			dark ? "text-[var(--color-text-light)]" : "text-[var(--color-text-dark)]",
		]}
	>
		{title}
	</h2>
</div>
