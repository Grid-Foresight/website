---
interface Props {
	variant: "chart" | "upload" | "training";
}

const { variant } = Astro.props;
---

<div
	aria-hidden="true"
	class="overflow-hidden rounded-xl bg-slate-900 shadow-lg"
>
	{
		variant === "chart" && (
			<div class="p-4">
				{/* Legend */}
				<div class="mb-2 flex gap-4 text-[10px] text-slate-400">
					<span class="flex items-center gap-1.5">
						<span class="h-0.5 w-3 rounded bg-slate-400" />
						Actual
					</span>
					<span class="flex items-center gap-1.5">
						<span class="h-0.5 w-3 rounded bg-indigo-500" />
						Predicted
					</span>
				</div>
				<svg
					viewBox="0 0 500 200"
					class="block w-full"
					preserveAspectRatio="xMidYMid meet"
				>
					{/* Grid */}
					<line x1="0" y1="50" x2="500" y2="50" stroke="#1e293b" stroke-width="0.5" />
					<line x1="0" y1="100" x2="500" y2="100" stroke="#1e293b" stroke-width="0.5" />
					<line x1="0" y1="150" x2="500" y2="150" stroke="#1e293b" stroke-width="0.5" />
					{/* Shaded area */}
					<polygon
						points="285,82 357,55 428,42 500,38 500,65 428,68 357,80 285,105"
						fill="#6366f1"
						opacity="0.1"
					/>
					{/* Actual line */}
					<polyline
						points="0,120 71,92 142,108 214,78 285,88"
						fill="none"
						stroke="#94a3b8"
						stroke-width="1.5"
						stroke-dasharray="4,3"
						stroke-linecap="round"
						stroke-linejoin="round"
					/>
					{/* Predicted line */}
					<polyline
						points="0,125 71,98 142,105 214,74 285,82 357,55 428,42 500,38"
						fill="none"
						stroke="#6366f1"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					/>
				</svg>
				<div class="mt-1 flex justify-between text-[9px] text-slate-500">
					<span>Mon</span>
					<span>Tue</span>
					<span>Wed</span>
					<span>Thu</span>
					<span>Fri</span>
					<span>Sat</span>
					<span>Sun</span>
				</div>
			</div>
		)
	}

	{
		variant === "upload" && (
			<div class="p-5">
				<div class="flex flex-col items-center rounded-lg border-2 border-dashed border-slate-600 px-6 py-8 text-center">
					{/* Upload icon */}
					<svg
						class="size-8 text-slate-400"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
						<polyline points="17 8 12 3 7 8" />
						<line x1="12" y1="3" x2="12" y2="15" />
					</svg>
					<p class="mt-3 text-xs text-slate-400">Drop files here or browse</p>
				</div>
				<div class="mt-4 flex items-center gap-3 rounded-lg bg-slate-800/50 px-3 py-2">
					{/* File icon */}
					<svg
						class="size-4 shrink-0 text-slate-400"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
						<path d="M14 2v4a2 2 0 0 0 2 2h4" />
					</svg>
					<div class="min-w-0 flex-1">
						<p class="truncate text-[11px] text-slate-300">wind_farm_alpha_2024.csv</p>
						<div class="mt-1 h-1.5 rounded-full bg-slate-700">
							<div class="h-full w-[73%] rounded-full bg-indigo-500" />
						</div>
						<p class="mt-0.5 text-[9px] text-slate-500">73% uploaded</p>
					</div>
				</div>
			</div>
		)
	}

	{
		variant === "training" && (
			<div class="flex flex-col gap-3 p-5">
				{/* Dropdown */}
				<div class="flex items-center justify-between rounded-lg bg-slate-800 px-3 py-2 text-xs text-slate-300">
					<span>Target: Power Output (MW)</span>
					<svg
						class="size-3 text-slate-400"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="m6 9 6 6 6-6" />
					</svg>
				</div>
				{/* Date range */}
				<div class="flex items-center justify-between rounded-lg bg-slate-800 px-3 py-2 text-xs text-slate-300">
					<span>Jan 2024 — Dec 2024</span>
					<svg
						class="size-3 text-slate-400"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M8 2v4" />
						<path d="M16 2v4" />
						<rect width="18" height="18" x="3" y="4" rx="2" />
						<path d="M3 10h18" />
					</svg>
				</div>
				{/* Train button */}
				<div class="rounded-lg bg-indigo-500 px-3 py-2.5 text-center text-xs font-semibold text-white">
					Start Training
				</div>
				{/* Progress */}
				<div class="rounded-lg bg-slate-800/50 px-3 py-2">
					<div class="flex items-center justify-between text-[10px]">
						<span class="text-slate-400">Training...</span>
						<span class="text-indigo-400">42%</span>
					</div>
					<div class="mt-1 h-1.5 rounded-full bg-slate-700">
						<div class="h-full w-[42%] rounded-full bg-indigo-500" />
					</div>
				</div>
			</div>
		)
	}
</div>
