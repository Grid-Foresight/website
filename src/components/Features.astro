---
const features = [
	{
		title: "Research-Grade Forecasting",
		description:
			"ML models built on algorithms published in top-tier energy systems journals and validated across diverse grid conditions.",
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/></svg>`,
	},
	{
		title: "Peer-Reviewed Methodology",
		description:
			"Every forecasting approach traces to published research. No black boxes — transparent, reproducible, citation-backed methods.",
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>`,
	},
	{
		title: "Continuous Model Improvement",
		description:
			"Active research feeds the platform. New findings from the lab become production features through rigorous validation pipelines.",
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
	},
	{
		title: "Enterprise Data Pipeline",
		description:
			"Ingest, validate, and process energy data at scale. Built for the messy reality of operational grid data.",
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/></svg>`,
	},
	{
		title: "Real-Time Accuracy Monitoring",
		description:
			"Track forecast performance against actuals. Automated alerts when model accuracy drifts beyond configured thresholds.",
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/></svg>`,
	},
	{
		title: "Production-Grade Security",
		description:
			"SOC 2 compliant infrastructure with role-based access, audit logging, and encrypted data at rest and in transit.",
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="16" r="1"/><rect x="3" y="10" width="18" height="12" rx="2"/><path d="M7 10V7a5 5 0 0 1 10 0v3"/></svg>`,
	},
];
---

<section id="platform" aria-labelledby="features-heading" class="bg-bg-warm py-16 md:py-24">
	<div class="mx-auto max-w-[80rem] px-6">
		<div class="text-center">
			<span class="text-xs font-semibold uppercase tracking-[0.08em] text-primary">
				PLATFORM CAPABILITIES
			</span>
			<h2
				id="features-heading"
				class="mt-4 font-display text-3xl font-bold text-text md:text-4xl"
			>
				Research Rigor, Production Scale
			</h2>
		</div>

		<div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
			{
				features.map((feature) => (
					<div class="rounded border border-border bg-white p-6">
						<div class="text-secondary" set:html={feature.icon} />
						<h3 class="mt-4 font-display text-lg font-semibold text-text">
							{feature.title}
						</h3>
						<p class="mt-2 text-base text-text-secondary">{feature.description}</p>
					</div>
				))
			}
		</div>
	</div>
</section>
