---
import { PiggyBank, Rocket, ShieldCheck } from "@lucide/astro";

const cards = [
	{
		Icon: Rocket,
		headline: "Models Deploy in Hours, Not Weeks",
		description:
			"Automated pipelines handle data ingestion, feature engineering, training, and validation. Your team configures; the platform executes.",
		badge: "60% ↑ deployment speed",
	},
	{
		Icon: PiggyBank,
		headline: "25% Lower Operational Costs",
		description:
			"Better forecasts mean fewer imbalance penalties, optimized reserves, and reduced manual intervention. The savings compound across your portfolio.",
		badge: "25% ↓ operational costs",
	},
	{
		Icon: ShieldCheck,
		headline: "Sub-Minute Predictions at Scale",
		description:
			"Production-grade infrastructure delivers forecasts on demand. Continuous monitoring ensures models stay accurate as grid conditions evolve.",
		badge: "< 60s prediction latency",
	},
];
---

<section id="platform" class="section-reveal bg-bg-dark py-20 lg:py-28">
	<div class="mx-auto max-w-[var(--max-width)] px-6">
		<div class="mx-auto mb-12 max-w-[640px] text-center">
			<h2 class="font-display text-[clamp(1.75rem,4vw,3rem)] font-bold text-text-on-dark">
				Outcomes, Not Features
			</h2>
			<p class="mt-4 text-lg text-text-on-dark-muted">
				Every capability maps to a measurable business result.
			</p>
		</div>

		<div class="grid gap-8 md:grid-cols-3">
			{
				cards.map((card) => (
					<div class="rounded-lg border border-neutral-700 bg-bg-dark-card p-8 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
						<card.Icon size={48} class="text-primary" />
						<h3 class="mt-4 font-display text-xl font-semibold text-text-on-dark lg:text-2xl">
							{card.headline}
						</h3>
						<p class="mt-3 leading-relaxed text-text-on-dark-muted">{card.description}</p>
						<span class="mt-4 inline-block rounded-full bg-primary/10 px-3 py-1 text-sm font-medium text-primary">
							{card.badge}
						</span>
					</div>
				))
			}
		</div>
	</div>
</section>
