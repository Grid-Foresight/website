---
const stages = [
	{
		label: "Ingest",
		description:
			"Raw energy data flows in — CSVs, APIs, or streaming sources. Automated validation, gap-filling, and normalization on arrival.",
		icon: "upload",
		active: false,
	},
	{
		label: "Train",
		description:
			"Models learn from historical patterns. Configure features, evaluation splits, and compare models. Track RMSE, MAE, and MAPE.",
		icon: "brain",
		active: false,
	},
	{
		label: "Predict",
		description:
			"Forecasts at any resolution — hourly, 15-minute, or sub-minute. Sub-minute latency with calibrated confidence intervals.",
		icon: "zap",
		active: true,
	},
	{
		label: "Monitor",
		description:
			"Track prediction accuracy in real time. Detect drift. Retrain when performance degrades.",
		icon: "eye",
		active: false,
	},
];
---

<section id="how-it-works" class="relative bg-bg-deep py-16 md:py-24" aria-labelledby="pipeline-heading">
	<!-- Subtle radial background -->
	<div class="pointer-events-none absolute inset-0" aria-hidden="true">
		<div
			class="bg-glow-primary-ellipse absolute top-1/2 left-1/2 h-[500px] w-[800px] -translate-x-1/2 -translate-y-1/2"
		>
		</div>
	</div>

	<div class="relative mx-auto max-w-[1280px] px-6 md:px-8">
		<div class="mb-16 text-center">
			<h2
				id="pipeline-heading"
				class="font-display text-3xl font-bold tracking-tight text-text-primary sm:text-4xl"
			>
				How it works
			</h2>
			<p class="mt-4 text-text-secondary">
				Four stages from raw data to production predictions. Fully automated. Observable end to end.
			</p>
		</div>

		<!-- Pipeline stages -->
		<div class="animate-on-scroll-stagger grid grid-cols-1 gap-6 md:grid-cols-4 md:gap-0">
			{
				stages.map((stage, i) => (
					<div class="flex items-stretch md:items-center">
						<div
							class:list={[
								"flex w-full flex-col items-center rounded-[--radius-md] border bg-bg-base p-6 text-center",
								stage.active
									? "border-primary/40 animate-pulse-glow"
									: "border-bg-subtle",
							]}
						>
							<!-- Icon -->
							<div class="mb-4 flex h-10 w-10 items-center justify-center rounded-[--radius-sm] bg-bg-elevated text-text-secondary">
								{stage.icon === "upload" && (
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
										<polyline points="17 8 12 3 7 8" />
										<line x1="12" y1="3" x2="12" y2="15" />
									</svg>
								)}
								{stage.icon === "brain" && (
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z" />
										<path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z" />
										<path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4" />
										<path d="M17.599 6.5a3 3 0 0 0 .399-1.375" />
										<path d="M6.003 5.125A3 3 0 0 0 6.401 6.5" />
										<path d="M3.477 10.896a4 4 0 0 1 .585-.396" />
										<path d="M19.938 10.5a4 4 0 0 1 .585.396" />
										<path d="M6 18a4 4 0 0 1-1.967-.516" />
										<path d="M19.967 17.484A4 4 0 0 1 18 18" />
									</svg>
								)}
								{stage.icon === "zap" && (
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z" />
									</svg>
								)}
								{stage.icon === "eye" && (
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0" />
										<circle cx="12" cy="12" r="3" />
									</svg>
								)}
							</div>

							<h3 class="font-display text-base font-semibold text-text-primary">
								{stage.label}
							</h3>
							<p class="mt-2 text-sm leading-relaxed text-text-secondary">
								{stage.description}
							</p>
						</div>

						{/* Connector arrow (not after last item) */}
						{i < stages.length - 1 && (
							<div class="hidden shrink-0 items-center px-2 text-bg-subtle md:flex" aria-hidden="true">
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
									<line x1="0" y1="12" x2="18" y2="12" stroke="#334155" stroke-width="1.5" stroke-dasharray="4 3" />
									<polyline points="15,8 20,12 15,16" stroke="#334155" stroke-width="1.5" fill="none" />
								</svg>
							</div>
						)}
					</div>
				))
			}
		</div>
	</div>
</section>
