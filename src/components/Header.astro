---
import Menu from "./icons/Menu.astro";
import X from "./icons/X.astro";

const navLinks = [
	{ label: "Features", href: "#features" },
	{ label: "How It Works", href: "#how-it-works" },
];

const appUrl = "https://app.gridforesight.com";
---

<div id="scroll-sentinel" class="absolute top-0 h-1" aria-hidden="true"></div>

<header
	class="fixed top-0 right-0 left-0 z-50 transition-[background-color,border-color] duration-200"
>
	<nav
		aria-label="Main navigation"
		class="mx-auto flex max-w-[var(--width-content)] items-center justify-between px-6 py-4"
	>
		<!-- Logo -->
		<a href="/" class="font-display text-xl font-bold tracking-tight text-slate-900">
			GridForesight
		</a>

		<!-- Desktop nav -->
		<ul class="hidden items-center gap-8 md:flex">
			{
				navLinks.map((link) => (
					<li>
						<a
							href={link.href}
							class="text-sm font-medium text-slate-600 transition-colors hover:text-slate-900"
						>
							{link.label}
						</a>
					</li>
				))
			}
		</ul>

		<!-- Desktop CTA -->
		<a
			href={appUrl}
			class="hidden rounded-[var(--radius-default)] bg-primary px-6 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-primary-hover md:inline-flex"
			target="_blank"
			rel="noopener noreferrer"
		>
			Start Forecasting
		</a>

		<!-- Mobile menu toggle -->
		<input
			type="checkbox"
			id="mobile-menu-toggle"
			class="peer sr-only"
			aria-label="Toggle navigation menu"
		/>
		<label
			for="mobile-menu-toggle"
			class="relative z-50 flex h-11 w-11 cursor-pointer items-center justify-center rounded-[var(--radius-default)] text-slate-700 transition-colors hover:bg-slate-100 md:hidden"
		>
			<span class="icon-menu"><Menu size={24} /></span>
			<span class="icon-close hidden"><X size={24} /></span>
		</label>

		<!-- Mobile menu panel -->
		<div
			class="fixed inset-0 top-0 z-40 invisible translate-x-full bg-white transition-all duration-300 peer-checked:visible peer-checked:translate-x-0 md:hidden"
		>
			<div class="flex h-full flex-col px-6 pt-20 pb-8">
				<ul class="flex flex-col gap-2">
					{
						navLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="mobile-nav-link block rounded-[var(--radius-default)] px-4 py-3 text-lg font-medium text-slate-700 transition-colors hover:bg-slate-50"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
				<div class="mt-auto">
					<a
						href={appUrl}
						class="block w-full rounded-[var(--radius-default)] bg-primary px-6 py-3.5 text-center text-base font-semibold text-white transition-colors hover:bg-primary-hover"
						target="_blank"
						rel="noopener noreferrer"
					>
						Start Forecasting
					</a>
				</div>
			</div>
		</div>
	</nav>
</header>

<style>
	#mobile-menu-toggle:checked ~ label .icon-menu {
		display: none;
	}
	#mobile-menu-toggle:checked ~ label .icon-close {
		display: block;
	}
</style>

<script>
	const s = document.getElementById("scroll-sentinel");
	const h = document.querySelector("header");
	if (s && h) {
		new IntersectionObserver(([e]) => {
			h.classList.toggle("bg-white", !e.isIntersecting);
			h.classList.toggle("border-b", !e.isIntersecting);
			h.classList.toggle("border-slate-200", !e.isIntersecting);
		}).observe(s);
	}

	const toggle = document.getElementById("mobile-menu-toggle") as HTMLInputElement;
	if (toggle) {
		for (const link of document.querySelectorAll(".mobile-nav-link")) {
			link.addEventListener("click", () => {
				toggle.checked = false;
			});
		}
	}
</script>
