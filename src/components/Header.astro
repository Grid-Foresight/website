---
import { Image } from "astro:assets";
import { ArrowRight } from "@lucide/astro";
import logo from "../assets/images/bubble-G-small.png";

const navItems = [
	{ label: "Platform", href: "#platform" },
	{ label: "Research", href: "#research" },
	{ label: "Results", href: "#results" },
];

const appUrl = "https://app.gridforesight.com";
---

<header
	id="site-header"
	class="fixed top-0 z-50 w-full transition-colors duration-300 data-[scrolled]:bg-bg-dark/80 data-[scrolled]:backdrop-blur-md"
>
	<div class="mx-auto flex h-16 max-w-[var(--max-width)] items-center justify-between px-6 lg:h-20">
		<a href="/" aria-label="GridForesight home">
			<Image src={logo} alt="GridForesight" height={36} width={36} class="h-9 w-9" />
		</a>

		<nav class="hidden items-center gap-8 md:flex" aria-label="Main navigation">
			{
				navItems.map((item) => (
					<a
						href={item.href}
						class="text-sm font-medium text-text-on-dark-muted transition-colors hover:text-text-on-dark"
					>
						{item.label}
					</a>
				))
			}
		</nav>

		<div class="flex items-center gap-4">
			<a
				href={appUrl}
				class="hidden items-center gap-2 rounded-full bg-primary px-5 py-2 text-sm font-semibold text-white transition-all hover:bg-primary-hover hover:shadow-lg md:inline-flex"
			>
				Start Forecasting
				<ArrowRight size={16} />
			</a>

			<button
				id="menu-toggle"
				type="button"
				class="inline-flex items-center justify-center rounded-md p-2 text-text-on-dark-muted transition-colors hover:text-text-on-dark md:hidden"
				aria-expanded="false"
				aria-controls="mobile-menu"
				aria-label="Toggle menu"
			>
				<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
			</button>
		</div>
	</div>

	<div
		id="mobile-menu"
		class="hidden border-t border-neutral-700 bg-bg-dark/95 backdrop-blur-md md:hidden"
	>
		<div class="flex flex-col gap-2 px-6 py-4">
			<a
				href={appUrl}
				class="inline-flex items-center justify-center gap-2 rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-white transition-all hover:bg-primary-hover"
			>
				Start Forecasting
				<ArrowRight size={16} />
			</a>
			{
				navItems.map((item) => (
					<a
						href={item.href}
						class="rounded-md px-3 py-2 text-sm font-medium text-text-on-dark-muted transition-colors hover:bg-bg-dark-card hover:text-text-on-dark"
					>
						{item.label}
					</a>
				))
			}
		</div>
	</div>
</header>

<script>
	const sentinel = document.getElementById("scroll-sentinel");
	const header = document.getElementById("site-header");
	if (sentinel && header) {
		const observer = new IntersectionObserver(
			([entry]) => {
				header.toggleAttribute("data-scrolled", !entry.isIntersecting);
			},
			{ threshold: 0 },
		);
		observer.observe(sentinel);
	}

	const toggle = document.getElementById("menu-toggle");
	const menu = document.getElementById("mobile-menu");
	if (toggle && menu) {
		toggle.addEventListener("click", () => {
			const expanded = toggle.getAttribute("aria-expanded") === "true";
			toggle.setAttribute("aria-expanded", String(!expanded));
			menu.classList.toggle("hidden");
		});
	}
</script>
