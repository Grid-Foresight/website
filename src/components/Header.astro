---
const navLinks = [
	{ label: "Features", href: "#features" },
	{ label: "How It Works", href: "#how-it-works" },
];
const appUrl = "https://app.gridforesight.com";
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/80 backdrop-blur-lg">
	<nav class="mx-auto flex max-w-[1280px] items-center justify-between px-6 py-4">
		<!-- Wordmark -->
		<a href="/" class="font-display text-xl font-bold">
			<span class="text-slate-800">Grid</span><span class="text-primary">Foresight</span>
		</a>

		<!-- Desktop nav -->
		<ul class="hidden items-center gap-8 md:flex">
			{
				navLinks.map((link) => (
					<li>
						<a
							href={link.href}
							class="font-body text-[15px] font-medium text-slate-600 transition-colors hover:text-slate-800"
						>
							{link.label}
						</a>
					</li>
				))
			}
		</ul>

		<!-- Desktop CTA -->
		<div class="hidden items-center gap-3 md:flex">
			<a
				href={appUrl}
				class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-primary-hover"
				rel="noopener noreferrer"
			>
				Start Forecasting
			</a>
		</div>

		<!-- Mobile hamburger (CSS-only) -->
		<input type="checkbox" id="menu-toggle" class="peer sr-only" aria-hidden="true" />
		<label
			for="menu-toggle"
			class="relative z-50 cursor-pointer p-2 md:hidden"
			aria-label="Toggle menu"
		>
			<!-- Hamburger icon -->
			<svg
				class="size-6 text-slate-700"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<line x1="4" y1="6" x2="20" y2="6" />
				<line x1="4" y1="12" x2="20" y2="12" />
				<line x1="4" y1="18" x2="20" y2="18" />
			</svg>
		</label>

		<!-- Mobile nav drawer -->
		<div
			class="invisible fixed inset-x-0 top-[65px] z-30 border-b border-slate-200 bg-white p-6 opacity-0 transition-all duration-200 peer-checked:visible peer-checked:opacity-100 md:hidden"
		>
			<ul class="flex flex-col gap-4">
				{
					navLinks.map((link) => (
						<li>
							<a
								href={link.href}
								class="block font-body text-base font-medium text-slate-600 transition-colors hover:text-slate-800"
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
			<div class="mt-6 flex flex-col gap-3">
				<a
					href={appUrl}
					class="rounded-lg bg-primary px-4 py-2.5 text-center text-sm font-semibold text-white transition-colors hover:bg-primary-hover"
					rel="noopener noreferrer"
				>
					Start Forecasting
				</a>
			</div>
		</div>
	</nav>
</header>
