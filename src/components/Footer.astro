---
const productLinks = [
	{ label: "How It Works", href: "#how-it-works" },
	{ label: "Integrations", href: "#integrations" },
];
---

<footer class="border-t border-bg-subtle bg-bg-deep" aria-label="Site footer">
	<div class="mx-auto max-w-[1280px] px-6 py-12 md:px-8 md:py-16">
		<div class="grid grid-cols-1 gap-10 md:grid-cols-2">
			<!-- Brand column -->
			<div>
				<a href="/" class="font-display text-base font-bold tracking-tight">
					<span class="text-text-primary">Grid</span><span class="text-primary"
						>Foresight</span
					>
				</a>
				<p class="mt-2 text-sm text-text-secondary">
					ML-powered energy forecasting
				</p>
			</div>

			<!-- Product column -->
			<div>
				<h3 class="mb-4 text-sm font-semibold text-text-primary">Product</h3>
				<ul class="flex flex-col gap-2" role="list">
					{
						productLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="text-sm text-text-secondary transition-colors duration-150 hover:text-text-primary"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</div>

	<!-- Bottom bar -->
	<div class="border-t border-bg-subtle py-6">
		<p class="text-center text-[13px] text-text-secondary">
			&copy; 2026 GridForesight. All rights reserved.
		</p>
	</div>
</footer>
