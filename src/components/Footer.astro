---
const productLinks = [
	{ label: "Features", href: "#features" },
	{ label: "How It Works", href: "#how-it-works" },
];
---

<footer class="bg-slate-900 text-slate-300">
	<div class="mx-auto max-w-[var(--width-content)] px-6 py-12 md:py-16">
		<div class="grid grid-cols-1 gap-8 sm:grid-cols-2">
			<!-- Brand -->
			<div>
				<span class="font-display text-lg font-bold text-white">GridForesight</span>
				<p class="mt-3 text-sm text-slate-300">ML-powered energy forecasting</p>
				<p class="mt-4 text-sm text-slate-500">
					&copy; 2026 GridForesight Inc. All rights reserved.
				</p>
			</div>

			<!-- Product -->
			<div>
				<h3 class="mb-4 font-display text-sm font-semibold tracking-wide text-white uppercase">
					Product
				</h3>
				<ul class="flex flex-col gap-2.5">
					{
						productLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="text-sm text-slate-300 transition-colors hover:text-white"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>

		<!-- Bottom bar -->
		<div class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-slate-700 pt-6 sm:flex-row">
			<p class="text-sm text-slate-500">Built in Canada</p>
			<p class="text-sm text-slate-500">
				Privacy &middot; Terms
			</p>
		</div>
	</div>
</footer>
